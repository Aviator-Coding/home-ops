{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Auto merge all container digest updates",
      matchDatasources: ["docker"],
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["digest"],
      ignoreTests: false,
    },
    {
      description: "Auto merge all container and helm patch updates",
      matchDatasources: ["docker", "helm", "github-releases", "github-tags"],
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["patch"],
      ignoreTests: false,
    },
    {
      description: "Auto merge all container and helm minor updates",
      matchDatasources: ["docker", "helm", "github-releases", "github-tags"],
      automerge: true,
      matchUpdateTypes: ["minor"],
      ignoreTests: false,
    },
  ],
}
