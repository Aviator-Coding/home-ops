---
# Bootstrap-only secrets, injected from 1Password via vals (ref+op://) and
# applied before External Secrets / Flux take over. Keep this to the MINIMUM
# needed to break the chicken-and-egg: once onepassword-connect + ESO and Flux
# (SOPS) are up, everything else is reconciled from Git. Other secrets (e.g.
# cloudflare tunnel) are seeded post-bootstrap by ESO and must NOT live here.
#
# Values are base64 (verbatim copies of the live Secret `data` fields), so a
# bootstrap reproduces the running Secret byte-for-byte. Uses `data:` (not
# `stringData:`) — vals injects the base64 string directly.
---
apiVersion: v1
kind: Secret
metadata:
  name: onepassword-secret
  namespace: security
data:
  1password-credentials.json: ref+op://Home-Lab/1password/OP_CREDENTIALS_JSON
  token: ref+op://Home-Lab/1password/OP_CONNECT_TOKEN
---
apiVersion: v1
kind: Secret
metadata:
  name: sops-age-secret
  namespace: flux-system
data:
  age.agekey: ref+op://Home-Lab/sops/SOPS_PRIVATE_KEY
